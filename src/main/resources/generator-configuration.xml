<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE generatorConfiguration PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd" >
<generatorConfiguration>

    <context id="sss" targetRuntime="MyBatis3" >
        <commentGenerator type="org.hkpc.dtd.component.postgres.mybatis.generator.CustomCommentGenerator">
            <property name="dateFormat" value="yyyy/MM/dd"/>
        </commentGenerator>

        <!--连接数据库 connect to the database-->
        <jdbcConnection driverClass="org.postgresql.Driver"
                        connectionURL="jdbc:postgresql://localhost:5432/postgres"
                        userId="postgres"
                        password="postgres">
        </jdbcConnection>

        <!--生成实体类，targetPackage是包名，targetProject是生成的包在工程中的哪个文件夹下 generate the model class-->
        <javaModelGenerator targetPackage="org.hkpc.dtd.component.postgres.model" targetProject="src/main/java">
            <property name="enableSubPackages" value="true"/>
            <property name="trimStrings" value="true"/>
        </javaModelGenerator>

        <!--生成.xml文件 generate the .xml files-->
        <sqlMapGenerator targetPackage="mapper" targetProject="src/main/resources/">
            <property name="enableSubPackages" value="true"/>
        </sqlMapGenerator>

        <!--生成dao层接口 generate the dao classes-->
<!--        <javaClientGenerator type="ANNOTATEDMAPPER" targetPackage="org.hkpc.dtd.component.postgres.dao" targetProject="src/main/java">-->
        <javaClientGenerator type="XMLMAPPER" targetPackage="org.hkpc.dtd.component.postgres.dao" targetProject="src/main/java">
            <property name="enableSubPackages" value="true"/>
        </javaClientGenerator>


        <!--数据库表名配置,tablename是数据库的表名，domainObjectName是生成实体类的类名 config the tablename to generate codes, domainObjectName is the class name-->
<!--        <table tableName="demo_rule" domainObjectName="DemoRule" enableCountByExample="false" enableUpdateByExample="false" enableDeleteByExample="false" enableSelectByExample="false" selectByExampleQueryId="false" >-->
<!--        </table>-->
