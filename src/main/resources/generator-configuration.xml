<!--        you can use this test_mybatis_generator table to test how to use MybatiGenerator.java to generate Mybatis code for a new Database table-->
<!--        中文注释：你可以使用这个test_mybatis_generator表来测试如何使用MybatiGenerator.java为一个新的数据库表生成Mybatis代码-->
        <table tableName="test_mybatis_generator" domainObjectName="TestMybatisGenerator" enableCountByExample="false" enableUpdateByExample="false" enableDeleteByExample="false" enableSelectByExample="false" selectByExampleQueryId="false" >
        </table>



    </context>
</generatorConfiguration>
